<Window x:Class="Butubukuai.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Butubukuai"
        mc:Ignorable="d"
        Title="不吐不快 (Butubukuai) - 核心控制台" SizeToContent="Height" MinHeight="750" Width="1050"
        WindowStartupLocation="CenterScreen" Background="#F4F6F9"
        Icon="pack://application:,,,/logo.ico">

    <!-- 全局容器 -->
    <Grid>
        <!-- 主内容区域 -->
        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：采集与控制区 -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel>
                    <!-- 第一部分：系统麦克风 -->
                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="1. 系统麦克风采集" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10" FontSize="16"/>
                        
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="选择你的“耳朵”：" Margin="0,0,0,5" Foreground="#666"/>
                            <ComboBox x:Name="MicComboBox" DisplayMemberPath="Key" SelectedValuePath="Value" Height="30" Padding="5,0"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="实时音量：" Margin="0,0,0,5" Foreground="#666"/>
                            <ProgressBar x:Name="VolumeProgressBar" Height="10" Minimum="0" Maximum="1" 
                                         Foreground="#4CAF50" Background="#E0E0E0" BorderBrush="#CCC" BorderThickness="1"/>
                        </StackPanel>

                        <Button x:Name="ToggleRecordButton" Content="[第 1 步] 开启麦克风监听" Height="35" 
                                Click="ToggleRecordButton_Click" Background="#2196F3" Foreground="White" 
                                BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- 第二部分：OBS 控制配置 -->
                    <StackPanel Margin="0,0,0,30">
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="2. 绑定 OBS" FontWeight="Bold" Foreground="#333" FontSize="16"/>
                            <TextBlock x:Name="ObsStatusTextBlock" Grid.Column="1" Text="未连接" Foreground="#F44336" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="#F9F9F9" BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="💡 此区域参数无特殊要求，无需修改" Foreground="#AAA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="IP 地址：" Margin="0,0,0,5" Foreground="#888" FontSize="12"/>
                                        <TextBox x:Name="ObsIpTextBox" Text="127.0.0.1" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="端口：" Margin="0,0,0,5" Foreground="#888" FontSize="12"/>
                                        <TextBox x:Name="ObsPortTextBox" Text="4455" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="连接密码：" Margin="0,0,0,5" Foreground="#888" FontSize="12"/>
                                        <PasswordBox x:Name="ObsPasswordBox" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="美化音轨道名称：" Margin="0,0,0,5" Foreground="#888" FontSize="12"/>
                                        <TextBox x:Name="ObsMediaSourceNameTextBox" Text="美化音轨道" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,5">
                                    <TextBlock Margin="0,0,0,5">
                                        <Run Text="OBS 高级音频偏移 (毫秒):" Foreground="#888" FontSize="12"/>
                                        <Run Text=" (💡 无特定需求，保持默认 2000 无需修改)" Foreground="#AAA" FontSize="11"/>
                                    </TextBlock>
                                    <TextBox x:Name="ObsSyncDelayTextBox" Text="2000" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button x:Name="ConnectObsButton" Content="[第 2 步] 掌控 OBS 导播" Height="35" Click="ConnectObsButton_Click" 
                                Background="#FF9800" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,20" FontWeight="Bold"/>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="目标闭麦通道 (连接后获取)：" Margin="0,0,0,5" Foreground="#333" FontWeight="Bold"/>
                            <ComboBox x:Name="ObsSourceComboBox" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Margin="0,0,0,5">
                                <Run Text="美化音介入时机微调 (-1000 到 +1000): [ " Foreground="#333" FontWeight="Bold"/>
                                <Run Text="{Binding Value, ElementName=FineTuneOffsetSlider}" Foreground="#1976D2" FontWeight="Bold"/>
                                <Run Text=" ]" Foreground="#333" FontWeight="Bold"/>
                            </TextBlock>
                            <Slider x:Name="FineTuneOffsetSlider" Minimum="-1000" Maximum="1000" Value="0" AutoToolTipPlacement="TopLeft" TickFrequency="10" SmallChange="10" LargeChange="10" IsSnapToTickEnabled="True"/>
                        </StackPanel>

                        <Border Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="5" Padding="10">
                            <StackPanel>
                                <TextBlock Text="🎯 精准校准舱 (内部声学自测)" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,10"/>
                                
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="RecordTestAudioButton" Grid.Column="0" Content="🔴 录制 5 秒测试音" Height="30" Click="RecordTestAudio_Click" Background="#F44336" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                                    <Button x:Name="PlayVerifyAudioButton" Grid.Column="2" Content="▶️ 播放并验证对齐" Height="30" IsEnabled="False" Click="PlayVerifyAudio_Click" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                                </Grid>

                                <TextBlock TextWrapping="Wrap" Foreground="#2E7D32" FontSize="13">
                                    💡 玩法：点击录制，然后随意说一句话（包含违禁词）。录制期间会自动监听。若成功捕获违禁词，即可点击右侧播放。如果听到的‘哔’声没有刚好盖住自己刚才的那句话，请调整上方的【微调滑块】后再次点击播放验证！
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 第三部分：AI 云端对接 -->
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="3. 阿里百炼语音接口" FontWeight="Bold" FontSize="16" Foreground="#333"/>
                            <TextBlock x:Name="SttStatusTextBlock" Grid.Column="1" Text="未连接" Foreground="#F44336" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="AI 钥匙 (API Key):" Margin="0,0,0,5" Foreground="#666"/>
                            <TextBox x:Name="ApiKeyTextBox" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                        </StackPanel>
                        
                        <Button x:Name="TestSttConnectButton" Content="[第 3 步] 连通 AI 大脑" Height="35" Click="TestSttConnectButton_Click"
                                Background="#9C27B0" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 右侧：配置表与日志区 -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="4. AI 屏蔽词与专属美化音字典" FontWeight="Bold" Margin="0,0,0,10" FontSize="16" Foreground="#333"/>
                    
                    <DataGrid Grid.Row="1" x:Name="RuleGroupsDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="True"
                              Background="White" AlternatingRowBackground="#F9F9F9" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEE"
                              RowHeight="50" ColumnHeaderHeight="35" BorderBrush="#DDD" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="规则组名" Binding="{Binding GroupName}" Width="110" />
                            <DataGridTemplateColumn Header="限制词池 / 宏" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Words}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Words, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="2" VerticalContentAlignment="Top"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="专属美化音路径" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding SoundPath}" VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1" Content="浏览..." Width="60" Click="BrowseSoundButton_Click" Background="#E0E0E0" BorderThickness="0" Margin="5,4" Cursor="Hand" Focusable="False"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding SoundPath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,15,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="AddRowButton" Content="➕ 新增词池规则组" Height="35" Padding="15,0" Click="AddRowButton_Click" 
                                Background="#E3F2FD" Foreground="#1976D2" BorderThickness="1" BorderBrush="#BBDEFB" Cursor="Hand" FontWeight="Bold"/>

                        <Button x:Name="SaveConfigButton" Grid.Column="2" Content="💾 生效并保存" Height="35" Padding="20,0" Click="SaveConfigButton_Click" 
                                Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                    </Grid>

                    <!-- 调试追踪区域 -->
                    <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="15" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock Text="AI 捕捉字幕追踪器:" Margin="0,0,0,5" Foreground="#666" FontWeight="Bold"/>
                            <TextBox x:Name="RecognizedResultTextBox" Height="100" TextWrapping="Wrap" IsReadOnly="True" Background="#EFEFEF" Padding="5" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 悬浮帮助按钮 (Top Right) -->
        <Button x:Name="HelpButton" Content="?" Width="46" Height="46" HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="0,25,25,0" Click="HelpButton_Click" Background="#00bcd4" Foreground="White" 
                FontSize="24" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Panel.ZIndex="10">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="23"/>
                </Style>
            </Button.Resources>
            <Button.Effect>
                <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="5" ShadowDepth="2"/>
            </Button.Effect>
        </Button>

        <!-- 右侧遮罩与抽屉面板 (Flyout) -->
        <Grid x:Name="HelpFlyout" Visibility="Collapsed" Panel.ZIndex="20">
            <!-- 半透明黑色遮罩 -->
            <Border Background="Black" Opacity="0.4" MouseLeftButtonDown="HelpButton_Click" Cursor="Hand"/>
            
            <!-- 右侧面板 -->
            <Border Width="400" HorizontalAlignment="Right" Background="White" Padding="25">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="20" ShadowDepth="-5"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="3分钟开播指南" FontSize="24" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>
                        <Button Content="✕" Width="30" Height="30" Click="HelpButton_Click" HorizontalAlignment="Right"
                                Background="Transparent" BorderThickness="0" FontSize="18" Foreground="#999" Cursor="Hand" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 说明书内容 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                        <StackPanel>
                            <!-- Step 1 -->
                            <Border Margin="0,0,0,10" Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="1" CornerRadius="5" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="[第 1 步] 找耳朵：在左侧选好你的麦克风。对着它说话，看到绿条在跳，说明它听见了。" TextWrapping="Wrap" FontWeight="Bold" FontSize="14" Foreground="#1565C0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Grid.Column="1" Content="查看大图" Tag="pack://siteoforigin:,,,/HelpImages/step1.png" Click="ShowLargeImage_Click" Cursor="Hand" Padding="10,5" Background="White" BorderBrush="#2196F3" Foreground="#2196F3" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Step 2 -->
                            <Border Margin="0,0,0,10" Background="#F3E5F5" BorderBrush="#E1BEE7" BorderThickness="1" CornerRadius="5" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="[第 2 步] 设外挂 (最重要!)：在 OBS 来源里添加【媒体源】命名为美化音轨道。接着在音频混合器点高级属性，把麦克风的“同步偏移”改为 2000ms。" TextWrapping="Wrap" FontWeight="Bold" FontSize="14" Foreground="#6A1B9A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Grid.Column="1" Content="查看大图" Tag="pack://siteoforigin:,,,/HelpImages/step2.png" Click="ShowLargeImage_Click" Cursor="Hand" Padding="10,5" Background="White" BorderBrush="#9C27B0" Foreground="#9C27B0" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Step 3 -->
                            <Border Margin="0,0,0,10" Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="5" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="[第 3 步] 连导播台：回到软件点击“一键连接”。看到右侧绿字亮起，说明“接头”成功。" TextWrapping="Wrap" FontWeight="Bold" FontSize="14" Foreground="#2E7D32" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Grid.Column="1" Content="查看大图" Tag="pack://siteoforigin:,,,/HelpImages/step3.png" Click="ShowLargeImage_Click" Cursor="Hand" Padding="10,5" Background="White" BorderBrush="#4CAF50" Foreground="#4CAF50" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Step 4 -->
                            <Border Margin="0,0,0,10" Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="1" CornerRadius="5" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock TextWrapping="Wrap" FontWeight="Bold" FontSize="14" Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,10,0">
                                        [第 4 步] 通大脑：点击 <Hyperlink NavigateUri="https://dashscope.console.aliyun.com/apiKey" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#1E88E5" TextDecorations="Underline">获取 API Key</Hyperlink> 注册，把钥匙复制到软件框内并点击连通。
                                    </TextBlock>
                                    <Button Grid.Column="1" Content="查看大图" Tag="pack://siteoforigin:,,,/HelpImages/step4.png" Click="ShowLargeImage_Click" Cursor="Hand" Padding="10,5" Background="White" BorderBrush="#FF9800" Foreground="#FF9800" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Step 5 -->
                            <Border Margin="0,0,0,10" Background="#FFEBEE" BorderBrush="#FFCDD2" BorderThickness="1" CornerRadius="5" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="[第 5 步] 靶场试音：在左下角[精准校准舱]录音5秒。听回放调滑块，直到哔声盖住脏话 (参考值: -500左右)，点击保存！" TextWrapping="Wrap" FontWeight="Bold" FontSize="14" Foreground="#C62828" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Grid.Column="1" Content="查看大图" Tag="pack://siteoforigin:,,,/HelpImages/step5.png" Click="ShowLargeImage_Click" Cursor="Hand" Padding="10,5" Background="White" BorderBrush="#F44336" Foreground="#F44336" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 大图查看遮罩层 -->
        <Grid x:Name="LargeImageViewer" Visibility="Collapsed" Panel.ZIndex="30" Background="#EE000000" MouseLeftButtonDown="LargeImageViewer_MouseLeftButtonDown" Cursor="Hand">
            <!-- 图片容器 -->
            <Image x:Name="LargeImageControl" Margin="50" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            
            <!-- 提示文本 -->
            <TextBlock Text="点击任意处关闭大图" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30" IsHitTestVisible="False" Opacity="0.8"/>
            
            <!-- 显式的关闭按钮 -->
            <Button Content="✕" Width="40" Height="40" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,20,0"
                    Background="Transparent" BorderThickness="0" FontSize="28" Foreground="White" Cursor="Hand" Click="CloseLargeImageButton_Click"/>
        </Grid>
    </Grid>
</Window>
