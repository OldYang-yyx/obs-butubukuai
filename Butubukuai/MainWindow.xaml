<Window x:Class="Butubukuai.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Butubukuai"
        mc:Ignorable="d"
        Title="不吐不快 (Butubukuai) - 麦克风与 OBS 测试" Height="480" Width="450"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 第一部分：系统麦克风 -->
        <Border Grid.Row="0" BorderBrush="#EEE" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15" Background="#FAFAFA">
            <StackPanel>
                <TextBlock Text="1. 系统麦克风采集" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15" FontSize="14"/>
                
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="选择麦克风：" Margin="0,0,0,5"/>
                    <ComboBox x:Name="MicComboBox" DisplayMemberPath="Key" SelectedValuePath="Value" Height="28"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="实时音量：" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="VolumeProgressBar" Height="20" Minimum="0" Maximum="1" 
                                 Foreground="#4CAF50" Background="#E0E0E0" BorderBrush="#CCC" BorderThickness="1"/>
                </StackPanel>

                <Button x:Name="ToggleRecordButton" Content="开始采集" Height="30" 
                        Click="ToggleRecordButton_Click" Background="#2196F3" Foreground="White" 
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- 第二部分：OBS 控制配置 -->
        <Border Grid.Row="1" BorderBrush="#EEE" BorderThickness="1" CornerRadius="5" Padding="15" Background="#FAFAFA">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="2. OBS WebSocket 连接" FontWeight="Bold" Foreground="#333" FontSize="14"/>
                    <TextBlock x:Name="ObsStatusTextBlock" Grid.Column="1" Text="未连接" Foreground="#F44336" FontWeight="Bold" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="IP 地址：" Margin="0,0,0,5"/>
                        <TextBox x:Name="ObsIpTextBox" Text="127.0.0.1" Height="25" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="端口：" Margin="0,0,0,5"/>
                        <TextBox x:Name="ObsPortTextBox" Text="4455" Height="25" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="连接密码：" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="ObsPasswordBox" Height="25" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <Button x:Name="ConnectObsButton" Content="连接 OBS" Height="30" Click="ConnectObsButton_Click" 
                        Background="#FF9800" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,15"/>

                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,0,0,15" Padding="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="OBS 麦克风测试：" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ObsSourceComboBox" ToolTip="下拉选择你要控制的 OBS 音轨" Margin="0,0,10,0" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
                            <ToggleButton x:Name="TestMuteToggleButton" Grid.Column="1" Content="测试静音" Height="30" Width="100" 
                                          Click="TestMuteToggleButton_Click" BorderThickness="1" Cursor="Hand" Style="{StaticResource {x:Type ToggleButton}}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

    </Grid>
</Window>
